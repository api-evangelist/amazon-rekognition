    "FaceMatchThreshold": {
      "type": "float",
      "example": 80.0
    },
    "QualityFilter": {
      "type": "string",
      "enum": [
        "NONE",
        "AUTO",
        "LOW",
        "MEDIUM",
        "HIGH"
      ]
    }
